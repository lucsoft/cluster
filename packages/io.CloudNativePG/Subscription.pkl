  publicationDBName: String?

  /// The name of the publication inside the PostgreSQL database in the "publisher"
  publicationName: String

  /// The policy for end-of-life maintenance of this subscription
  subscriptionReclaimPolicy: ("delete" | "retain")?
}

/// The name of the PostgreSQL cluster that identifies the "subscriber"
class Cluster {
  /// Name of the referent. This field is effectively required, but due to backwards compatibility is
  /// allowed to be empty. Instances of this type with an empty value here are almost certainly wrong.
  /// More info: https://kubernetes.io/docs/concepts/overview/working-with-objects/names/#names
