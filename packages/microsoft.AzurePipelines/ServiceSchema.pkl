  routeTraffic: RouteTrafficHook?

  /// Post route traffic hook for runOnce deployment strategy
  postRouteTraffic: PostRouteTrafficHook?

  /// On success or failure hook for runOnce deployment strategy
  on: OnSuccessOrFailureHook?
}

class RollingDeploymentStrategy {
  /// Maximum number of jobs running in parallel
  maxParallel: NonEmptyString?

  /// Pre deploy hook for rolling deployment strategy
  preDeploy: PreDeployHook?

  /// Deploy hook for rolling deployment strategy
  deploy: DeployHook?

  /// Route traffic hook for rolling deployment strategy
  routeTraffic: RouteTrafficHook?

  /// Post route traffic hook for rolling deployment strategy
  postRouteTraffic: PostRouteTrafficHook?

  /// On success or failure hook for rolling deployment strategy
  on: OnSuccessOrFailureHook?
}

class CanaryDeploymentStrategy {
  /// Maximum batch size for deployment
  increments: SequenceOfNonEmptyString?

  /// Pre deploy hook for canary deployment strategy
  preDeploy: PreDeployHook?

  /// Deploy hook for canary deployment strategy
  deploy: DeployHook?

  /// Route traffic hook for canary deployment strategy
  routeTraffic: RouteTrafficHook?

  /// Post route traffic hook for canary deployment strategy
  postRouteTraffic: PostRouteTrafficHook?

  /// On success or failure hook for canary deployment strategy
  on: OnSuccessOrFailureHook?
}

class AgentPhase extends PhaseBase {
  /// Queue where this phase will run
  queue: PhaseQueueTarget?
}

class ServerPhase extends PhaseBase {
  /// True if this is an agent-less phase (runs on server)
  server: PhaseServerTarget?
}

class PhaseTemplate {
  /// Reference to a template for this phase
  template: NonEmptyString?

  /// Parameters used in a phase template
  parameters: MappingOfStringString?
}

class PhaseQueueTargetAlternate1 {
  /// Time to wait for the phase to cancel before forcibly terminating it
  cancelTimeoutInMinutes: NonEmptyString?

  /// Container resource name
  container: NonEmptyString?

  /// List of demands (for a private queue)
  demands: PhaseTargetDemands?

  matrix: PhaseTargetMatrix?

  /// Name of a queue
  name: NonEmptyString?

  /// Maximum number of parallel agent executions
  parallel: NonEmptyString?

  /// Time to wait before cancelling the phase
  timeoutInMinutes: NonEmptyString?

  workspace: PhaseTargetWorkspace?
}

class PhaseServerTargetAlternate1 {
  /// Time to wait for the job to cancel before forcibly terminating it
  cancelTimeoutInMinutes: NonEmptyString?

  matrix: PhaseTargetMatrix?

  /// Maximum number of parallel agent executions
  parallel: NonEmptyString?

  /// Time to wait before cancelling the job
  timeoutInMinutes: NonEmptyString?
}

class PhaseTargetWorkspace {
  /// Scorch the repo before fetching?
  clean: NonEmptyString?
}

class StepsTemplate {
  /// Step-specific parameters
  parameters: TemplateParameters?

  /// A list of steps to run
  steps: Steps?
}

class ScriptStep extends TaskBase {
  /// An inline script
  script: NonEmptyString

  /// Fail the task if output is sent to Stderr?
  failOnStderr: NonEmptyString?

  /// Start the script with this working directory
  workingDirectory: NonEmptyString?
}

class PowerShellStep extends TaskBase {
  /// Inline PowerShell or reference to a PowerShell file
  powershell: NonEmptyString

  errorActionPreference: NonEmptyString?

  /// Fail the task if output is sent to Stderr?
  failOnStderr: NonEmptyString?

  /// Check the final exit code of the script to determine whether the step succeeded?
  ignoreLASTEXITCODE: NonEmptyString?

  /// Start the script with this working directory
  workingDirectory: NonEmptyString?
}

class PwshStep extends TaskBase {
  /// Inline PowerShell or reference to a PowerShell file
  pwsh: NonEmptyString

  errorActionPreference: NonEmptyString?

  /// Fail the task if output is sent to Stderr?
  failOnStderr: NonEmptyString?

  /// Check the final exit code of the script to determine whether the step succeeded?
  ignoreLASTEXITCODE: NonEmptyString?

  /// Start the script with this working directory
  workingDirectory: NonEmptyString?
}

class BashStep extends TaskBase {
  /// An inline script
  bash: NonEmptyString

  /// Fail the task if output is sent to Stderr?
  failOnStderr: NonEmptyString?

  /// Start the script with this working directory
  workingDirectory: NonEmptyString?
}

class CheckoutStep extends TaskBase {
  /// Alias of the repository resource to check out or 'none'
  checkout: NonEmptyString?

  /// Scorch the repo before fetching?
  clean: NonEmptyString?

  /// Depth of Git graph to fetch
  fetchDepth: NonEmptyString?

  /// Filter Git history
  fetchFilter: NonEmptyString?

  /// Fetch tags?
  fetchTags: NonEmptyString?

  /// Fetch Git-LFS objects?
  lfs: NonEmptyString?

  /// Keep credentials available for later use?
  persistCredentials: NonEmptyString?

  /// Check out Git submodules?
  submodules: NonEmptyString?

  /// Path of the repository to check out
  path: NonEmptyString?

  /// Directories for sparse checkout in cone mode and prioritized over sparseCheckoutPatterns if both
  /// properties are provided
  sparseCheckoutDirectories: NonEmptyString?

  /// Patterns for sparse checkout in non-cone mode that are ignored if sparseCheckoutDirectories is
  /// provided
  sparseCheckoutPatterns: NonEmptyString?

  /// Make the repository root directory the default working directory?
  workspaceRepo: NonEmptyString?
}

class DownloadStep extends TaskBase {
  /// Reference to the pipeline
  download: NonEmptyString

  /// Name of the artifact to download
  artifact: NonEmptyString?

  /// Pattern to download files from artifact
  patterns: NonEmptyString?
}

class DownloadBuildStep extends TaskBase {
  /// ID for the build resource
  downloadBuild: NonEmptyString?

  /// Name of the artifact to download
  artifact: NonEmptyString?

  /// Path to download the artifact into
  path: NonEmptyString?

  /// Downloads the files which matches the patterns
  patterns: NonEmptyString?

  /// Inputs for the task
  inputs: MappingOfStringString?
}

class GetPackageStep extends TaskBase {
  /// ID for the package resource
  getPackage: NonEmptyString?

  /// Path to download the package into
  path: NonEmptyString?
}

class UploadStep extends TaskBase {
  upload: NonEmptyString?

  artifact: NonEmptyString?
}

class PublishStep extends TaskBase {
  publish: NonEmptyString?

  artifact: NonEmptyString?
}

class TemplateStep {
  /// Reference to a template for this step
  template: NonEmptyString?

  /// Parameters used in a step template
  parameters: MappingOfStringString?
}

class ReviewAppStep extends TaskBase {
  reviewApp: NonEmptyString?
}

class StepTargetAlternate1 {
  /// Container to target (or 'host' for host machine)
  container: NonEmptyString?

  /// Set of allowed logging commands ('any' or 'restricted')
  commands: NonEmptyString?

  /// Restrictions on which variables that can be set
  settableVariables: VariableRestrictions?
}

class JobDecoratorSteps {
  /// A list of steps to run in this job
  steps: Tasks?
}

abstract class TaskBase {
  /// Evaluate this condition expression to determine whether to run this task
  condition: NonEmptyString?

  /// Continue running even on failure?
  continueOnError: Boolean1?

  /// Human-readable name for the task
  displayName: NonEmptyString?

  /// Environment in which to run this task
  target: StepTarget?

  /// Run this task when the job runs?
  enabled: Boolean1?

  /// Variables to map into the process's environment
  env: MappingOfStringString?

  /// ID of the step
  name: ReferenceName?

  /// Time to wait for this task to complete before the server kills it
  timeoutInMinutes: NonEmptyString?

  /// Number of retries if the task fails
  retryCountOnTaskFailure: NonEmptyString?
}

