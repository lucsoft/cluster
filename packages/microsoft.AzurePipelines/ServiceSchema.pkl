typealias NonEmptyString = String

typealias Sequence = Listing<AnyAllowExpressions>

typealias MappingOfStringString = Mapping<String, Any>

typealias AnyAllowExpressions =
  NonEmptyString | Listing<NonEmptyString | MappingOfStringString> | MappingOfStringString

typealias Pipeline = *StagedPipeline | PipelineJobs | PipelineJob

typealias Pr = String(matches(Regex("^none$"))) | BranchFilterArray | PrAlternate2

typealias Trigger = String(matches(Regex("^none$"))) | BranchFilterArray | TriggerAlternate2

typealias IncludeExcludeStringFilters =
  SequenceOfNonEmptyString | IncludeExcludeStringFiltersAlternate1

typealias BranchFilterArray = Listing<BranchFilter>

/// branch name or prefix filter
typealias BranchFilter = String(matches(Regex(#"^[^\/~\^\: \[\]\\]+(\/[^\/~\^\: \[\]\\]+)*$"#)))

typealias TemplateParameters = ExtendsParameters | MappingOfStringString

typealias TemplateParameterType =
  String(matches(Regex("^boolean$")))
    | String(matches(Regex("^container$")))
    | String(matches(Regex("^containerList$")))
    | String(matches(Regex("^deployment$")))
    | String(matches(Regex("^deploymentList$")))
    | String(matches(Regex("^job$")))
    | String(matches(Regex("^jobList$")))
    | String(matches(Regex("^legacyObject$")))
    | String(matches(Regex("^number$")))
    | String(matches(Regex("^object$")))
    | String(matches(Regex("^stage$")))
    | String(matches(Regex("^stageList$")))
    | String(matches(Regex("^step$")))
    | String(matches(Regex("^stepList$")))
    | String(matches(Regex("^string$")))
    | String(matches(Regex("^stringList$")))

typealias PipelineTemplateParameters = Listing<PipelineTemplateParameter>

typealias PipelineTemplateParameterType =
  String(matches(Regex("^boolean$")))
    | String(matches(Regex("^container$")))
    | String(matches(Regex("^containerList$")))
    | String(matches(Regex("^deployment$")))
    | String(matches(Regex("^deploymentList$")))
    | String(matches(Regex("^environment$")))
    | String(matches(Regex("^filePath$")))
    | String(matches(Regex("^job$")))
    | String(matches(Regex("^jobList$")))
    | String(matches(Regex("^number$")))
    | String(matches(Regex("^object$")))
    | String(matches(Regex("^pool$")))
    | String(matches(Regex("^secureFile$")))
    | String(matches(Regex("^serviceConnection$")))
    | String(matches(Regex("^stage$")))
    | String(matches(Regex("^stageList$")))
    | String(matches(Regex("^step$")))
    | String(matches(Regex("^stepList$")))
    | String(matches(Regex("^string$")))
    | String(matches(Regex("^stringList$")))

typealias Schedules = Listing<Schedule>

typealias Resources = ResourcesAlternate0 | Listing<LegacyResource>

typealias BuildResources = Listing<BuildResource>

typealias PackageResourceTrigger =
  String(matches(Regex("^none$"))) | String(matches(Regex("^true$")))

typealias PackageResources = Listing<PackageResource>

typealias ContainerResources = Listing<ContainerResource>

typealias ContainerArtifactType = String(matches(Regex("^ACR$"))) | NonEmptyString

typealias ContainerResourceTrigger =
  String(matches(Regex("^none$")))
    | String(matches(Regex("^true$")))
    | ContainerResourceTriggerAlternate2

typealias PipelineResources = Listing<PipelineResource>

typealias PipelineResourceTrigger =
  String(matches(Regex("^none$")))
    | String(matches(Regex("^true$")))
    | PipelineResourceTriggerAlternate2

typealias TriggerBranchFilter = TriggerBranchFilterAlternate0 | BranchFilterArray

typealias RepositoryResources = Listing<RepositoryResource>

typealias LegacyRepoResourceAlias = String(matches(Regex("^self$")))

typealias WebhookResources = Listing<WebhookResource>

typealias WebhookFilters = Listing<WebhookFilter>

typealias Variables = MappingOfStringString | *Listing<VariableEntry>

typealias VariableEntry = *Variable | VariableGroup | VariableTemplate

typealias Stages = Listing<StageEntry>

typealias StageEntry = *Stage | StageTemplate | Insertion

typealias Checks = Listing<Check>

/// Production readiness check
typealias CheckType = String(matches(Regex("^productionReadinessPolicy$")))

typealias LockBehavior =
  String(matches(Regex("^sequential$"))) | String(matches(Regex("^runLatest$")))

typealias StageTrigger = String(matches(Regex("^manual$"))) | String(matches(Regex("^automatic$")))

typealias ExtendsParameters = Listing<TemplateParameter>

typealias ExtendsTemplate =
  ExtendsTemplateAlternate0
    | ExtendsTemplateAlternate1
    | ExtendsTemplateAlternate2
    | ExtendsTemplateAlternate3

typealias ParametersTemplate =
  ParametersTemplateAlternate0
    | JobsTemplateAlternate0
    | ParametersTemplateAlternate2
    | ParametersTemplateAlternate3

typealias JobsTemplate = JobsTemplateAlternate0 | JobsTemplateAlternate1

typealias Jobs = Listing<JobEntry>

typealias JobEntry = *Job | DeploymentJob | JobTemplate | Insertion

/// Pool details
typealias Pool = NonEmptyString | PoolAlternate1

typealias PhaseTargetDemands = NonEmptyString | SequenceOfNonEmptyString

typealias JobContainer = NonEmptyString | JobContainerAlternate1 | JobContainerAlternate2

typealias JobStrategy = JobStrategyAlternate0 | JobStrategyAlternate1

typealias JobMatrix =
  Mapping<String(matches(Regex("^[A-Za-z0-9_]+$"))), MatrixProperties>(length >= 1) | NonEmptyString

/// Variable-value pair to pass in this matrix instance
typealias MatrixProperties = Mapping<String, Any>

/// Environment details
typealias DeploymentEnvironment = NonEmptyString | DeploymentEnvironmentAlternate1

typealias DeploymentStrategy =
  DeploymentStrategyAlternate0 | DeploymentStrategyAlternate1 | DeploymentStrategyAlternate2

typealias SequenceOfNonEmptyString = Listing<NonEmptyString>

typealias Phases = Listing<Phase>

typealias Phase = *AgentPhase | ServerPhase | PhaseTemplate

/// Queue details
typealias PhaseQueueTarget = NonEmptyString | PhaseQueueTargetAlternate1

typealias PhaseServerTarget = NonEmptyString | PhaseServerTargetAlternate1

/// List of permutations of variable values to run
typealias PhaseTargetMatrix = MappingOfStringString | NonEmptyString

typealias Steps = Listing<Step>

typealias Insertion = Mapping<String, Listing>

typealias Step =
  *Task
    | ScriptStep
    | PowerShellStep
    | PwshStep
    | BashStep
    | CheckoutStep
    | DownloadStep
    | DownloadBuildStep
    | GetPackageStep
    | UploadStep
    | PublishStep
    | TemplateStep
    | ReviewAppStep
    | Insertion

/// Step target
typealias StepTarget = NonEmptyString | StepTargetAlternate1

typealias VariableRestrictions = String(matches(Regex("^none$"))) | SequenceOfNonEmptyString

typealias Tasks = Listing<Task>

typealias JobDependsOn = NonEmptyString | Listing<NonEmptyString>

typealias ReferenceName = String(matches(Regex("^[-_A-Za-z0-9]*$")))

typealias Boolean1 =
  String(matches(Regex("^true$")))
    | String(matches(Regex("^y$")))
    | String(matches(Regex("^yes$")))
    | String(matches(Regex("^on$")))
    | String(matches(Regex("^false$")))
    | String(matches(Regex("^n$")))
    | String(matches(Regex("^no$")))
    | String(matches(Regex("^off$")))

typealias SequenceOfStringAllowExpressions = Listing<NonEmptyString>
