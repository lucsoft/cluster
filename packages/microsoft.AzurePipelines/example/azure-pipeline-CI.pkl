amends "../StagedPipeline.pkl"

import "../Expressions.pkl"
import "../Tasks.pkl"
import "../Variables.pkl"

name = "James"

stages {
  new {
    stage = "Test"
    displayName = "Test Stage"
    jobs {
      new {
        job = "PrintHelloWorld"
        steps {
          new ScriptStep {
            script =
              """
              echo "This is a Test!" \(Variables.Pipeline.Workspace)
              """
          }
          // Declarative compile-time `${{ if }}` / `${{ else }}` insertion,
          // built with the Class-As-Function `Conditional`.
          ...new Expressions.Conditional {
            condition = Expressions.equals(Expressions.variable("Agent.OS"), "Linux")
            then {
              new BashStep { bash = "echo running on linux" }
            }
            otherwise {
              new ScriptStep { script = "echo not linux" }
            }
          }.entries
        }
      }
    }
  }
  // The same `Conditional` also inserts whole stages.
  ...new Expressions.Conditional {
    condition = Expressions.equals(Expressions.parameter("env"), "prod")
    then {
      new Stage { stage = "Deploy" }
    }
  }.entries
}
