amends "package://pkg.pkl-lang.org/pkl-pantry/k8s.contrib.crd@4.2.1#/generate.pkl"
import "pkl:yaml"

// renovate: datasource=github-releases packageName=k3s-io/helm-controller
local version = "v0.17.2"
local baseUrl =
  "https://raw.githubusercontent.com/k3s-io/helm-controller/\(version)/pkg/crds/yaml/generated"

source = ""
baseApiGroup = "v1.helm.cattle.io"

k8sImportPath = "@k8s"

sourceContents =
  new YamlRenderer {
    isStream = true
  }.renderDocument(
    List(
      "helm.cattle.io_helmcharts.yaml",
      "helm.cattle.io_helmchartconfigs.yaml",
    ).map((item) -> (new yaml.Parser {}.parse(read("\(baseUrl)/\(item)")) as Dynamic)),
  )
