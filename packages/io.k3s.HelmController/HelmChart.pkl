/// HelmChartSpec represents the user-configurable details for installation and upgrade of a Helm chart
/// release.
class Spec {
  /// Pass Basic auth credentials to all domains. Helm CLI positional argument/flag: `--pass-credentials`
  authPassCredentials: Boolean?

  /// Reference to Secret of type kubernetes.io/basic-auth holding Basic auth credentials for the Chart
  /// repo.
  authSecret: AuthSecret?

  /// Specify the number of retries before considering the helm job failed.
