  valuesContent: String?

  /// Override complex Chart values via references to external Secrets. Helm CLI positional
  /// argument/flag: `--values`
  valuesSecrets: Listing<ValuesSecret>?

  /// Helm Chart version. Only used when installing from repository; ignored when .spec.chart or
  /// .spec.chartContent is used to install a specific chart archive. Helm CLI positional argument/flag:
  /// `--version`
  version: String?
