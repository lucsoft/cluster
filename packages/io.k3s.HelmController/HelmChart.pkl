  plainHTTP: Boolean?

  /// Custom PodSecurityContext for the helm job pod.
  podSecurityContext: PodSpec.PodSecurityContext?

  /// Helm Chart repository URL. Helm CLI positional argument/flag: `--repo`
  repo: String?

  /// Verify certificates of HTTPS-enabled servers using this CA bundle. Should be a string containing
  /// one or more PEM-encoded CA Certificates. Helm CLI positional argument/flag: `--ca-file`
  repoCA: String?

  /// Reference to a ConfigMap containing CA Certificates to be be trusted by Helm. Can be used along
