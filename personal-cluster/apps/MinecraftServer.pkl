amends "@ArgoCD/App.pkl"
import "@ArgoCD/Application.pkl"

name = "minecraft-server"
namespace = "argocd"

ignoreDifferences = new Listing<Application.ComparedToIgnoreDifference> {
  for (server in List("main", "atm10", "vanilla-create", "craftoria")) {
    new {
      group = "apps"
      kind = "Deployment"
      name = server
      jsonPointers {
        "/spec/replicas"
      }
    }
  }
}

source {
  repoURL = "https://github.com/lucsoft/cluster"
  targetRevision = "main"
  path = "personal-cluster"
  plugin {
    parameters {
      new {
        name = "path"
        string = "components/MinecraftServer.pkl"
      }
    }
  }
}
