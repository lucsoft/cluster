amends "@Resource/Entrypoint.pkl"

import "@itzg.minecraft/McRouter.pkl"
import "@itzg.minecraft/McServer.pkl"
import "@k8s/api/core/v1/Namespace.pkl"
import "@k8s/api/core/v1/Service.pkl"
import "@sops/includeSopsSecret.pkl"
import "@Workload/Workload.pkl"

local mcServers: Listing<McServer> = new {
  new {
    eula = true
    type = "VANILLA"
    workload {
      name = "main"
      namespace = "minecraft"
    }
  }
  new {
    type = "AUTO_CURSEFORGE"
    eula = true
    workload {
      name = "atm10"
      namespace = "minecraft"
    }
    motd = "Running: All The Mods 10"
    memory = 8.gb
    modpackSlug = "all-the-mods-10"
    curseforgeApiKey {
      secretKeyRef {
        name = "curseforge-apikey"
        key = "CF_API_KEY"
      }
    }
    curseforgeProjects {
      "distant-horizons"
      "bluemap"
      "chunky-pregenerator-forge"
      "ftb-chunks-for-bluemap"
      "minecolonies-bluemap-integration"
    }
  }
  new {
    eula = true
    type = "FABRIC"
    modrinthProjects {
      "fabric-api:0.138.3+1.21.10"
      "create-fly:1.21.10-6.0.8-4"
      "distanthorizons:2.3.6-b-1.21.10"
    }
    motd = "Running: Create Mod"
    workload {
      name = "vanilla-create"
      namespace = "minecraft"
      spec {
        containers {
          [0] {
            env {
              new {
                name = "VERSION"
                value = "1.21.10"
              }
            }
          }
        }
      }
    }
  }
}

local mcRouter = new McRouter {
  workload {
    deployment {
      spec {
        strategy {
          type = "Recreate"
        }
      }
    }
    namespace = "minecraft"
    spec {
      containers {
        [0] {
          // renovate: datasource=docker packageName=itzg/mc-router
          image = "docker.io/itzg/mc-router:1.43.0"
          env {
            new {
              name = "AUTO_SCALE_WEBHOOK_URL"
              value = "http://mc-router-scaler/scale"
            }
            new {
              name = "AUTO_SCALE_ASLEEP_MOTD"
              value = "Server is asleep. Join to wake it up!"
            }
            new {
              name = "AUTO_SCALE_LOADING_MOTD"
              value = "Server is waking up. Please wait..."
            }
            new {
              name = "AUTO_SCALE_DOWN_AFTER"
              value = "24h"
            }
          }
        }
      }
    }
  }
  servers {
    for (server in mcServers) {
      [server.workload.name + ".lucsoft.de"] = server.address
    }
  }
}

local mcRouterScaler = new Workload {
  name = "mc-router-scaler"
  namespace = "minecraft"
  type = "Deployment"
  spec {
    containers {
      new {
        name = "scaler"
        image = "ghcr.io/lucsoft/mc-router-scaler:0.1.1"
        ports {
          new {
            name = "http"
            containerPort = 8080
          }
        }
        env {
          new {
            name = "SCALE_MAP"
            value =
              new JsonRenderer {}.renderValue(new Mapping<String, String> {
                for (server in mcServers) {
                  [server.workload.name + ".lucsoft.de"] = server.workload.name
                }
              })
          }
        }
      }
    }
  }
  useServiceAccount = true
  policies {
    new {
      name = "mc-router-scaler"
      namespace = "minecraft"
      rules {
        new {
          apiGroups { "apps" }
          resources { "deployments" }
          verbs { "get" }
        }
        new {
          apiGroups { "apps" }
          resources { "deployments/scale" }
          verbs { "patch" }
        }
      }
    }
  }
}

resources {
  new Namespace {
    metadata {
      name = "minecraft"
      labels {
        ["pod-security.kubernetes.io/enforce"] = "privileged"
      }
    }
  }
  new Service {
    metadata {
      name = mcRouterScaler.name
      namespace = mcRouterScaler.namespace
    }
    spec {
      selector {
        ["app.kubernetes.io/name"] = mcRouterScaler.name
      }
      ports {
        new {
          name = "http"
          port = 80
          targetPort = "http"
        }
      }
    }
  }
  ...mcRouter.resources
  for (mcServer in mcServers) {
    ...(mcServer) {
      service {
        spec {
          selector = new {
            ["app.kubernetes.io/name"] = mcServer.workload.name
          }
        }
      }
    }.resources
  }
  ...mcRouterScaler.resources
  includeSopsSecret.includeSopsSecret(read("../secrets/curseforge-apikey.sops.yaml"))
}
