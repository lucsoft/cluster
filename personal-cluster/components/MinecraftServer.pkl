amends "@Resource/Entrypoint.pkl"

import "@itzg.minecraft/McRouter.pkl"
import "@itzg.minecraft/McServer.pkl"
import "@k8s/api/core/v1/Namespace.pkl"
import "@k8s/api/core/v1/Service.pkl"
import "@sops/includeSopsSecret.pkl"
import "@Workload/Workload.pkl"

local mcServers: Listing<McServer> = new {
  new {
    eula = true
    type = "VANILLA"
    workload {
      name = "main"
      namespace = "minecraft"
    }
  }
  new {
    type = "AUTO_CURSEFORGE"
    eula = true
    workload {
      name = "craftoria"
      namespace = "minecraft"
      deployment {
        spec {
          strategy {
            rollingUpdate {
              maxUnavailable = "100%"
              maxSurge = 0
            }
          }
        }
      }
    }
    motd = "Running: Craftoria"
    memory = 8.gb
    modpackSlug = "craftoria"
    curseforgeApiKey {
      secretKeyRef {
        name = "curseforge-apikey"
        key = "CF_API_KEY"
      }
    }
    modrinthProjects {
      "distanthorizons:3.0.3-b-1.21.1"
    }
    // curseforgeProjects {
    //   "distant-horizons"
    //   "bluemap"
    //   "chunky-pregenerator-forge"
    //   "ftb-chunks-for-bluemap"
    // }
  }
  new {
    type = "AUTO_CURSEFORGE"
    eula = true
    workload {
      name = "atm10"
      namespace = "minecraft"
    }
    motd = "Running: All The Mods 10"
    memory = 8.gb
    modpackSlug = "all-the-mods-10"
    curseforgeApiKey {
      secretKeyRef {
        name = "curseforge-apikey"
        key = "CF_API_KEY"
      }
    }
    curseforgeProjects {
      "distant-horizons"
      "bluemap"
      "chunky-pregenerator-forge"
      "ftb-chunks-for-bluemap"
      "minecolonies-bluemap-integration"
    }
  }
  new {
    eula = true
    type = "FABRIC"
    modrinthProjects {
      "fabric-api:0.138.4+1.21.10"
      "create-fly:1.21.10-6.0.9-2"
      "distanthorizons:3.0.3-b-1.21.10"
    }
    motd = "Running: Create Mod"
    version = "1.21.10"
    workload {
      name = "vanilla-create"
      namespace = "minecraft"
    }
  }
}

local voicePort = 24454

local mcRouter = new McRouter {
  workload {
    deployment {
      spec {
        strategy {
          type = "Recreate"
        }
      }
    }
    namespace = "minecraft"
    // svc-router routes Simple Voice Chat UDP; sidecar so it shares mc-router's node IP,
    // fed by mc-router's connection webhook. https://github.com/JLSchuler99/svc-router
    spec {
      containers {
        [0] {
          env {
            new {
              name = "WEBHOOK_URL"
              value = "http://localhost:8080/event"
            }
          }
        }
        new {
          name = "svc-router"
          // renovate: datasource=docker packageName=ghcr.io/jlschuler99/svc-router
          image = "ghcr.io/jlschuler99/svc-router:0.0.2"
          ports {
            new {
              name = "svc-voice"
              containerPort = voicePort
              hostPort = voicePort
              protocol = "UDP"
            }
          }
        }
      }
    }
  }
  // renovate: datasource=docker packageName=itzg/mc-router
  image = "docker.io/itzg/mc-router:1.43.0"
  autoscale = new McRouter.AutoScaleConfig {
    scaleEndpoint = "http://mc-router-scaler/scale"
    asleepMotd = "Server is asleep. Join to wake it up!"
    loadingMotd = "Server is waking up. Please wait..."
    scaleDownAfter = 15.min
  }
  servers {
    for (server in mcServers) {
      [server.workload.name + ".lucsoft.de"] = server.address
    }
  }
}

local mcRouterScaler = new Workload {
  name = "mc-router-scaler"
  namespace = "minecraft"
  type = "Deployment"
  spec {
    containers {
      new {
        name = "scaler"
        image = "ghcr.io/lucsoft/mc-router-scaler:0.1.1"
        ports {
          new {
            name = "http"
            containerPort = 8080
          }
        }
        env {
          new {
            name = "SCALE_MAP"
            value =
              new JsonRenderer {}.renderValue(new Mapping<String, String> {
                for (server in mcServers) {
                  [server.workload.name + ".lucsoft.de"] = server.workload.name
                }
              })
          }
        }
      }
    }
  }
  useServiceAccount = true
  policies {
    new {
      name = "mc-router-scaler"
      namespace = "minecraft"
      rules {
        new {
          apiGroups { "apps" }
          resources { "deployments" }
          verbs { "get" }
        }
        new {
          apiGroups { "apps" }
          resources { "deployments/scale" }
          verbs { "patch" }
        }
      }
    }
  }
}

resources {
  new Namespace {
    metadata {
      name = "minecraft"
      labels {
        ["pod-security.kubernetes.io/enforce"] = "privileged"
      }
    }
  }
  new Service {
    metadata {
      name = mcRouterScaler.name
      namespace = mcRouterScaler.namespace
    }
    spec {
      selector {
        ["app.kubernetes.io/name"] = mcRouterScaler.name
      }
      ports {
        new {
          name = "http"
          port = 80
          targetPort = "http"
        }
      }
    }
  }
  ...mcRouter.resources
  for (mcServer in mcServers) {
    // svc-router forwards voice UDP to "<server>.minecraft.svc:\(voicePort)"; expose it
    // on each backend service. No-op for servers without the Simple Voice Chat mod.
    ...(mcServer) {
      service {
        spec {
          ports {
            new {
              name = "voice"
              port = voicePort
              targetPort = voicePort
              protocol = "UDP"
            }
          }
        }
      }
    }.resources
  }
  ...mcRouterScaler.resources
  includeSopsSecret.includeSopsSecret(read("../secrets/curseforge-apikey.sops.yaml"))
}
